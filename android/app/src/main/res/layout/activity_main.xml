<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/urlBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入网址,或中文搜索"
            android:inputType="text"
            android:imeOptions="actionGo"
            android:maxLines="1"/>

        <Button
            android:id="@+id/goBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="打开"/>

        <androidx.mediarouter.app.MediaRouteButton
            android:id="@+id/routeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"/>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/shortcuts"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"/>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textSize="13sp"
        android:text="用法:选或输入视频网站 → 登录并播放 → 出现提示后点下面「📺 投屏到电视」,按提示选一次电视就会自动投(设备与电视需连同一 Wi-Fi)。"/>

    <Button
        android:id="@+id/castBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:text="📺 投屏到电视"/>

    <!-- 投屏后的遥控条:电视在放,这里只发指令。默认隐藏,有媒体在投时才显示。 -->
    <LinearLayout
        android:id="@+id/controls"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp"
        android:visibility="gone">

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button android:id="@+id/btnPlayPause"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="⏸ 暂停"/>
            <Button android:id="@+id/btnBack"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="⏪ -10s"/>
            <Button android:id="@+id/btnFwd"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="⏩ +30s"/>
            <Button android:id="@+id/btnStop"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="⏹ 停止"/>
        </LinearLayout>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <SeekBar android:id="@+id/seek"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"/>
            <TextView android:id="@+id/timeLabel"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textSize="13sp" android:text="0:00 / 0:00"/>
        </LinearLayout>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:text="倍速"/>
            <LinearLayout android:id="@+id/speedRow"
                android:orientation="horizontal"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:text="音量"/>
            <SeekBar android:id="@+id/volSeek"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:max="100"
                android:layout_marginStart="4dp"/>
            <Button android:id="@+id/btnMute"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔇 静音"/>
        </LinearLayout>

        <CheckBox android:id="@+id/chkAutoNext"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="13sp" android:checked="true"
            android:text="自动连播(实验):一集放完自动接下一集,依赖网站自带连播;保持 App 打开更稳"/>
    </LinearLayout>

    <WebView
        android:id="@+id/web"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>
